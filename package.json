{
  "name": "gtfs2lc",
  "version": "2.4.0",
  "description": "Mapping script from gtfs to (linked) connections",
  "main": "lib/gtfs2lc.js",
  "exports": {
    ".": "./lib/gtfs2lc.js",
    "./lib/*": "./lib/*",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "lib",
    "scripts/build-sncb.js",
    "baseUris-example.json",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "gtfs2lc": "./bin/gtfs2lc.js",
    "gtfs2lc-build": "./bin/gtfs2lc-build.js",
    "gtfs2lc-clean": "./bin/gtfs2lc-clean.js",
    "linkedconnections-joinandsort": "./bin/linkedconnections-sort.js"
  },
  "scripts": {
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "build:sncb": "node scripts/build-sncb.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pretest": "node scripts/prepare-tests.js",
    "test": "jest --runInBand",
    "test-ci": "jest --ci --runInBand --coverage",
    "typecheck": "tsc --project jsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LinkedConnections/gtfs2lc.git"
  },
  "homepage": "https://github.com/LinkedConnections/gtfs2lc#readme",
  "keywords": [
    "GTFS",
    "Linked Connections",
    "RDF"
  ],
  "author": "Pieter Colpaert",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "bugs": {
    "url": "https://github.com/LinkedConnections/gtfs2lc/issues"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "date-fns": "^4.4.0",
    "fast-csv": "^5.0.7",
    "level": "^10.0.0",
    "rdf-data-factory": "^2.0.2",
    "rdf-parser-ts": "^0.2.6",
    "rdfjs-jelly": "^0.1.x",
    "unzipper": "^0.12.5",
    "uri-templates": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.13.2",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.3.0"
    }
  }
}
